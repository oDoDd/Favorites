# 应用配置
DEBUG=True
HOST=0.0.0.0
PORT=8000

# LLM配置
# 选择LLM提供商: openai, glm, deepseek
LLM_PROVIDER=openai

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# GLM配置 (智谱AI)
# GLM_API_KEY=your_glm_api_key_here

# DeepSeek配置
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通用LLM配置 (如果上面的特定配置为空，则使用这些)
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=gpt-3.5-turbo

# 自动解析
AUTO_ANALYZE=true
